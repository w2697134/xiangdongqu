<view class="page">
  <view class="hero">
    <image class="hero__image" src="{{home.hero.image}}" mode="aspectFill" />
    <view class="hero__ribbon hero__ribbon--deep"></view>
    <view class="hero__ribbon hero__ribbon--bright"></view>
  </view>

  <view class="content">
    <view class="quick-panel">
      <view class="quick-grid">
        <button
          wx:for="{{home.navEntries}}"
          wx:key="label"
          class="quick-entry {{index === 4 ? 'quick-entry--offset' : ''}}"
          hover-class="quick-entry--hover"
          bindtap="handleNavTap"
          data-label="{{item.label}}"
        >
          <view class="quick-entry__icon">
            <image src="{{item.icon}}" mode="aspectFit" />
          </view>
          <text class="quick-entry__label">{{item.label}}</text>
        </button>
      </view>
    </view>

    <view class="section">
      <view class="section__head">
        <text class="section__title">{{home.panorama.title}}</text>
        <button class="section__more" bindtap="handleMore" data-title="{{home.panorama.title}}">更多</button>
      </view>
      <image class="wide-image" src="{{home.panorama.image}}" mode="aspectFill" />
    </view>

    <view class="section">
      <view class="section__head">
        <text class="section__title">{{home.vr.title}}</text>
        <button class="section__more" bindtap="handleMore" data-title="{{home.vr.title}}">更多</button>
      </view>
      <view class="vr-card" bindtap="handleNavTap" data-label="{{home.vr.title}}">
        <image class="vr-card__image" src="{{home.vr.image}}" mode="aspectFill" />
        <view class="vr-card__shade"></view>
        <view class="vr-card__badge">VR</view>
        <view class="vr-card__copy">
          <text class="vr-card__name">{{home.vr.name}}</text>
          <text class="vr-card__desc">{{home.vr.description}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section__head">
        <text class="section__title">{{home.history.title}}</text>
        <button class="section__more" bindtap="handleMore" data-title="{{home.history.title}}">更多</button>
      </view>
      <view class="history-grid">
        <view class="history-card" wx:for="{{home.history.cards}}" wx:key="title">
          <image class="history-card__image" src="{{item.image}}" mode="aspectFill" />
          <view class="history-card__body">
            <text class="history-card__title">{{item.title}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section__head">
        <text class="section__title">{{home.spirit.title}}</text>
        <button class="section__more" bindtap="handleMore" data-title="{{home.spirit.title}}">更多</button>
      </view>
      <view class="spirit-card">
        <image class="spirit-card__image" src="{{home.spirit.image}}" mode="aspectFill" />
        <view class="spirit-card__panel">
          <text class="spirit-card__keyword" wx:for="{{home.spirit.keywords}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section__head">
        <text class="section__title">{{home.value.title}}</text>
        <button class="section__more" bindtap="handleMore" data-title="{{home.value.title}}">更多</button>
      </view>
      <view class="value-card">
        <image class="value-card__icon" src="/assets/images/icon-value.png" mode="aspectFit" />
        <text class="value-card__summary">{{home.value.summary}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section__head">
        <text class="section__title">{{home.yunxiao.title}}</text>
        <button class="section__more" bindtap="handleMore" data-title="{{home.yunxiao.title}}">更多</button>
      </view>
      <image class="wide-image wide-image--city" src="{{home.yunxiao.image}}" mode="aspectFill" />
    </view>

    <view class="section section--last">
      <view class="section__head">
        <text class="section__title">{{home.news.title}}</text>
        <button class="section__more" bindtap="handleMore" data-title="{{home.news.title}}">更多</button>
      </view>
      <view class="news-list">
        <view class="news-item" wx:for="{{home.news.list}}" wx:key="title">
          <view class="news-item__icon"></view>
          <text class="news-item__title">{{item.title}}</text>
          <text class="news-item__source">{{item.source}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
