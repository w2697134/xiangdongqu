.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 14% 6%, rgba(194, 31, 36, 0.08), transparent 210rpx),
    linear-gradient(180deg, #fffaf2 0%, #f7ecdd 44%, #f6eee3 100%);
}

.hero {
  position: relative;
  width: 100%;
  height: 354rpx;
  overflow: hidden;
  background: #d8c4ad;
}

.hero__image {
  width: 100%;
  height: 100%;
}

.hero__ribbon {
  position: absolute;
  left: -8%;
  right: -8%;
  height: 62rpx;
  bottom: -10rpx;
  transform: skewY(-3deg);
  transform-origin: left bottom;
  border-radius: 50% 50% 0 0;
}

.hero__ribbon--deep {
  bottom: -20rpx;
  background: linear-gradient(90deg, #8f0809 0%, #c51a1d 34%, #7e0608 68%, #d42a22 100%);
  opacity: 0.95;
}

.hero__ribbon--bright {
  bottom: -34rpx;
  height: 78rpx;
  background: linear-gradient(90deg, #e43b25 0%, #b80d13 48%, #f0a044 62%, #a9070d 100%);
  opacity: 0.92;
}

.content {
  position: relative;
  z-index: 2;
  padding: 0 24rpx 42rpx;
  margin-top: -28rpx;
}

.quick-panel,
.section {
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid #f0dfca;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 28rpx rgba(112, 59, 34, 0.11);
}

.quick-panel {
  padding: 28rpx 10rpx 24rpx;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
}

.quick-entry {
  width: 25%;
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-direction: column;
  color: #4b2418;
}

.quick-entry--offset {
  margin-left: 12.5%;
}

.quick-entry--hover {
  opacity: 0.78;
}

.quick-entry__icon {
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f8e7d4;
  box-shadow: inset 0 0 0 2rpx #f2d5bd, 0 6rpx 14rpx rgba(127, 43, 24, 0.14);
}

.quick-entry__icon image {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.quick-entry__label {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 32rpx;
  font-weight: 600;
  color: #4a2218;
  text-align: center;
}

.section {
  margin-top: 18rpx;
  padding: 18rpx 22rpx 22rpx;
}

.section--last {
  margin-bottom: 10rpx;
}

.section__head {
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section__title {
  position: relative;
  padding-left: 14rpx;
  font-size: 31rpx;
  line-height: 42rpx;
  font-weight: 700;
  color: #24150f;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.section__title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 9rpx;
  width: 5rpx;
  height: 25rpx;
  border-radius: 5rpx;
  background: #b10e12;
}

.section__more {
  position: relative;
  padding-right: 22rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #7a3b2a;
}

.section__more::after {
  content: "";
  position: absolute;
  right: 4rpx;
  top: 13rpx;
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #7a3b2a;
  border-right: 2rpx solid #7a3b2a;
  transform: rotate(45deg);
}

.wide-image {
  width: 100%;
  height: 188rpx;
  margin-top: 12rpx;
  border-radius: 12rpx;
  background: #eadac7;
}

.wide-image--city {
  height: 202rpx;
}

.vr-card {
  position: relative;
  height: 206rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #efe2d4;
}

.vr-card__image,
.vr-card__shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.vr-card__shade {
  background: linear-gradient(90deg, rgba(38, 15, 9, 0.24), rgba(255, 244, 228, 0.22) 46%, rgba(255, 239, 218, 0.94) 100%);
}

.vr-card__badge {
  position: absolute;
  left: 22rpx;
  top: 26rpx;
  width: 76rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #3a241c;
  color: #fff6e9;
  font-size: 28rpx;
  line-height: 58rpx;
  text-align: center;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(39, 22, 13, 0.22);
}

.vr-card__copy {
  position: absolute;
  right: 28rpx;
  top: 52rpx;
  width: 310rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.vr-card__name {
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 700;
  color: #5a2218;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.vr-card__desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 32rpx;
  color: #6d4637;
}

.history-grid {
  display: flex;
  margin-top: 12rpx;
}

.history-card {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #fbf1e7;
  border: 1rpx solid #efd9c3;
}

.history-card:last-child {
  margin-right: 0;
}

.history-card__image {
  width: 100%;
  height: 118rpx;
  background: #e7d4bf;
}

.history-card__body {
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.history-card__title {
  max-width: 100%;
  font-size: 24rpx;
  line-height: 32rpx;
  color: #4a2419;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.spirit-card {
  position: relative;
  height: 188rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #ead7c2;
}

.spirit-card__image {
  width: 100%;
  height: 100%;
}

.spirit-card__panel {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 51%;
  display: flex;
  flex-wrap: wrap;
  align-content: center;
  justify-content: center;
  padding: 20rpx 18rpx;
  background: linear-gradient(90deg, rgba(255, 246, 232, 0.45), rgba(255, 244, 228, 0.96));
}

.spirit-card__keyword {
  width: 132rpx;
  margin: 7rpx 9rpx;
  font-size: 28rpx;
  line-height: 38rpx;
  color: #9d1515;
  font-weight: 700;
  text-align: center;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.value-card {
  min-height: 108rpx;
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 20rpx 22rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #fff5e8 0%, #f7e6d5 100%);
  border: 1rpx solid #edd2bc;
}

.value-card__icon {
  width: 74rpx;
  height: 74rpx;
  flex: 0 0 74rpx;
  margin-right: 22rpx;
}

.value-card__summary {
  font-size: 29rpx;
  line-height: 40rpx;
  font-weight: 700;
  color: #5b261b;
}

.news-list {
  margin-top: 8rpx;
}

.news-item {
  min-height: 70rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0dfcf;
}

.news-item:last-child {
  border-bottom: 0;
}

.news-item__icon {
  position: relative;
  width: 26rpx;
  height: 30rpx;
  flex: 0 0 26rpx;
  margin-right: 18rpx;
  border: 3rpx solid #b21616;
  border-radius: 2rpx;
  box-sizing: border-box;
}

.news-item__icon::before,
.news-item__icon::after {
  content: "";
  position: absolute;
  left: 5rpx;
  right: 5rpx;
  height: 3rpx;
  background: #b21616;
}

.news-item__icon::before {
  top: 8rpx;
}

.news-item__icon::after {
  top: 16rpx;
}

.news-item__title {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #3d241b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.news-item__source {
  flex: 0 0 auto;
  max-width: 142rpx;
  margin-left: 18rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8a5947;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
