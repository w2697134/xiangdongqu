<view class="detail-page">
  <view class="detail-hero">
    <view class="detail-copy">
      <text class="detail-eyebrow">{{eyebrow}}</text>
      <text class="detail-title">{{title}}</text>
      <text class="detail-status">{{status}}</text>
      <text class="detail-description">{{description}}</text>
    </view>

    <view class="detail-art" aria-hidden="true">
      <view class="paper paper-back"></view>
      <view class="paper paper-front">
        <view class="paper-line line-one"></view>
        <view class="paper-line line-two"></view>
        <view class="canal canal-main"></view>
        <view class="canal canal-soft"></view>
        <view class="seal">向东</view>
      </view>
    </view>
  </view>

  <view class="status-card">
    <view class="status-icon">{{label}}</view>
    <view class="status-copy">
      <text>栏目导览</text>
      <text>结合栏目主题呈现导览说明、档案线索与影像资料。</text>
    </view>
  </view>

  <view class="detail-list">
    <view wx:for="{{details}}" wx:key="title" class="detail-card">
      <text class="detail-title">{{item.title}}</text>
      <text class="detail-text">{{item.text}}</text>
    </view>
  </view>

  <view class="detail-note">{{note}}</view>

  <view class="detail-actions">
    <button class="action primary" bindtap="goHome">返回首页</button>
  </view>

  <view
    wx:if="{{consultOpen}}"
    class="consult-panel"
    style="transform: translateY({{panelY}}px);"
  >
    <view
      class="consult-head"
      bindtouchstart="onPanelTouchStart"
      bindtouchmove="onPanelTouchMove"
      bindtouchend="onPanelTouchEnd"
      bindtouchcancel="onPanelTouchEnd"
    >
      <image class="consult-icon" src="/assets/tab/bot.svg" mode="aspectFit" />
      <view class="consult-title">
        <text>智能咨询</text>
        <text>向东渠数字馆 AI 问答</text>
      </view>
      <button class="consult-close" bindtap="closeConsult">×</button>
    </view>
    <scroll-view class="consult-body" scroll-y="true">
      <view
        wx:for="{{consultMessages}}"
        wx:key="index"
        class="message {{item.role == 'assistant' ? 'assistant' : 'user'}}"
      >
        <rich-text nodes="{{item.html}}" />
      </view>
      <view wx:if="{{isConsulting}}" class="message assistant muted">回复中</view>
    </scroll-view>
    <view class="consult-input">
      <input
        value="{{consultInput}}"
        placeholder="输入想了解的内容"
        confirm-type="send"
        bindinput="onConsultInput"
        bindconfirm="submitConsult"
      />
      <button disabled="{{isConsulting || !consultInput}}" bindtap="submitConsult">发送</button>
    </view>
  </view>

  <view class="bottom-nav">
    <button
      wx:for="{{tabs}}"
      wx:key="id"
      class="bottom-tab {{activeTab == item.id ? 'active' : ''}}"
      data-tab="{{item.id}}"
      bindtap="onTabTap"
    >
      <view class="tab-core">
        <view class="tab-icon-wrap">
          <image class="tab-icon" src="{{item.icon}}" mode="aspectFit" />
          <text wx:if="{{item.badge}}" class="tab-badge">{{item.badge}}</text>
        </view>
        <view class="tab-label">
          <text>{{item.label}}</text>
        </view>
      </view>
    </button>
  </view>
</view>
