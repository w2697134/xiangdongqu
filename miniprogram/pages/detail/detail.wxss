.detail-page {
  min-height: 100vh;
  padding: 44rpx 28rpx calc(168rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 6%, rgba(255, 251, 239, 0.96), transparent 320rpx),
    radial-gradient(circle at 90% 72%, rgba(201, 163, 99, 0.18), transparent 360rpx),
    linear-gradient(180deg, #efe0cb 0%, #f6ebd9 42%, #efe6d6 100%);
  color: #2f2017;
}

.detail-hero {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(138, 91, 58, 0.18);
  border-radius: 16rpx;
  background:
    repeating-linear-gradient(0deg, rgba(138, 91, 58, 0.045) 0 1rpx, transparent 1rpx 22rpx),
    linear-gradient(145deg, rgba(255, 250, 241, 0.92), rgba(245, 226, 194, 0.78));
  box-shadow:
    0 24rpx 68rpx rgba(96, 50, 22, 0.16),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.44);
  padding: 46rpx 34rpx 36rpx;
}

.detail-copy {
  position: relative;
  z-index: 2;
}

.detail-eyebrow {
  display: inline-block;
  min-height: 48rpx;
  border: 1rpx solid rgba(170, 43, 49, 0.24);
  border-radius: 999rpx;
  background: rgba(170, 43, 49, 0.08);
  color: #aa2b31;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 48rpx;
  padding: 0 22rpx;
}

.detail-title {
  display: block;
  margin-top: 24rpx;
  color: #aa2b31;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.12;
}

.detail-status {
  display: block;
  margin-top: 20rpx;
  color: #173d31;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
}

.detail-description {
  display: block;
  margin-top: 18rpx;
  color: #846f5b;
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.78;
}

.detail-art {
  position: relative;
  height: 390rpx;
  margin-top: 42rpx;
}

.paper {
  position: absolute;
  border: 1rpx solid rgba(138, 91, 58, 0.18);
  border-radius: 12rpx;
  background:
    radial-gradient(circle at 24% 18%, rgba(255, 255, 255, 0.72), transparent 150rpx),
    radial-gradient(circle at 80% 82%, rgba(201, 163, 99, 0.18), transparent 190rpx),
    linear-gradient(145deg, #fffaf1, #f1dfbd);
  box-shadow: 0 20rpx 48rpx rgba(96, 50, 22, 0.16);
}

.paper-back {
  left: 78rpx;
  right: 22rpx;
  top: 42rpx;
  bottom: 16rpx;
  opacity: 0.58;
  transform: rotate(-5deg);
}

.paper-front {
  left: 8rpx;
  right: 64rpx;
  top: 4rpx;
  bottom: 32rpx;
  overflow: hidden;
}

.paper-front::before {
  content: "";
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 28rpx;
  bottom: 28rpx;
  border: 1rpx solid rgba(170, 43, 49, 0.16);
  border-radius: 8rpx;
}

.paper-line {
  position: absolute;
  left: 78rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: rgba(132, 87, 54, 0.26);
}

.line-one {
  top: 92rpx;
  width: 300rpx;
}

.line-two {
  top: 126rpx;
  width: 230rpx;
}

.canal {
  position: absolute;
  left: 48rpx;
  right: 44rpx;
  height: 128rpx;
  border-top: 14rpx solid rgba(23, 61, 49, 0.22);
  border-radius: 50% 50% 0 0;
}

.canal-main {
  top: 164rpx;
  transform: rotate(-8deg);
}

.canal-soft {
  top: 228rpx;
  border-top-color: rgba(170, 43, 49, 0.15);
  transform: rotate(-4deg);
}

.seal {
  position: absolute;
  right: 58rpx;
  bottom: 42rpx;
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 5rpx solid rgba(170, 43, 49, 0.82);
  border-radius: 12rpx;
  color: rgba(170, 43, 49, 0.88);
  font-family: "STKaiti", "KaiTi", "楷体", serif;
  font-size: 34rpx;
  font-weight: 900;
  transform: rotate(-8deg);
}

.status-card {
  display: flex;
  gap: 22rpx;
  margin-top: 28rpx;
  border: 1rpx solid rgba(138, 91, 58, 0.16);
  border-radius: 12rpx;
  background: rgba(255, 250, 241, 0.78);
  box-shadow: 0 14rpx 36rpx rgba(96, 50, 22, 0.08);
  padding: 26rpx;
}

.status-icon {
  flex: 0 0 auto;
  min-width: 128rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(23, 61, 49, 0.1);
  color: #173d31;
  font-size: 24rpx;
  font-weight: 900;
}

.status-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 8rpx;
  color: #846f5b;
  font-size: 27rpx;
  line-height: 1.55;
}

.status-copy text:first-child {
  color: #2f2017;
  font-weight: 900;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.detail-card {
  border: 1rpx solid rgba(138, 91, 58, 0.16);
  border-radius: 12rpx;
  background: rgba(255, 250, 241, 0.76);
  box-shadow: 0 12rpx 30rpx rgba(96, 50, 22, 0.08);
  padding: 24rpx;
}

.detail-title {
  display: block;
  color: #173d31;
  font-size: 27rpx;
  font-weight: 900;
}

.detail-text {
  display: block;
  margin-top: 10rpx;
  color: #2f2017;
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 26rpx;
  line-height: 1.62;
}

.detail-note {
  margin-top: 22rpx;
  border-left: 6rpx solid rgba(170, 43, 49, 0.42);
  color: #173d31;
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 25rpx;
  line-height: 1.62;
  padding-left: 18rpx;
}

.detail-actions {
  display: flex;
  margin-top: 30rpx;
}

.action {
  width: 100%;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  border: 1rpx solid rgba(170, 43, 49, 0.24);
  border-radius: 999rpx;
  background: rgba(255, 250, 241, 0.72);
  color: #aa2b31;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  padding: 0;
  text-align: center;
  box-sizing: border-box;
}

.action.primary {
  border-color: rgba(170, 43, 49, 0.72);
  background: #aa2b31;
  color: #fff7eb;
  box-shadow: 0 12rpx 28rpx rgba(128, 33, 39, 0.18);
}

.action::after {
  border: 0;
}

.consult-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  z-index: 80;
  overflow: hidden;
  border: 1rpx solid rgba(138, 91, 58, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 250, 241, 0.98);
  box-shadow: 0 22rpx 58rpx rgba(71, 43, 25, 0.2);
}

.consult-head {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid rgba(138, 91, 58, 0.14);
  background: linear-gradient(180deg, #fffdf4, #f6e6c9);
  padding: 14rpx 18rpx;
  box-sizing: border-box;
}

.consult-icon {
  width: 52rpx;
  height: 52rpx;
}

.consult-title {
  flex: 1;
}

.consult-title text:first-child {
  display: block;
  color: #aa2b31;
  font-size: 29rpx;
  font-weight: 900;
}

.consult-title text:last-child {
  display: block;
  margin-top: 3rpx;
  color: #846f5b;
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 21rpx;
  font-weight: 800;
}

.consult-close {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  background: rgba(170, 43, 49, 0.08);
  color: #aa2b31;
  font-size: 38rpx;
  line-height: 1;
  padding: 0;
}

.consult-close::after,
.bottom-tab::after {
  border: 0;
}

.consult-body {
  max-height: 460rpx;
  padding: 20rpx 18rpx;
  box-sizing: border-box;
}

.message {
  max-width: 88%;
  margin-bottom: 14rpx;
  border-radius: 14rpx;
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 25rpx;
  line-height: 1.55;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
  white-space: normal;
}

.message.assistant {
  background: #f4e5cf;
  color: #2f2017;
}

.message.user {
  margin-left: auto;
  background: #aa2b31;
  color: #fff7eb;
}

.message.muted {
  color: #846f5b;
}

.consult-input {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx;
  gap: 14rpx;
  border-top: 1rpx solid rgba(138, 91, 58, 0.14);
  padding: 16rpx 22rpx 20rpx;
  box-sizing: border-box;
}

.consult-input input {
  width: 100%;
  min-width: 0;
  height: 72rpx;
  border: 1rpx solid rgba(138, 91, 58, 0.18);
  border-radius: 8rpx;
  background: #fffaf1;
  color: #2f2017;
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 25rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.consult-input button {
  width: 100%;
  min-width: 0;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  border: 0;
  border-radius: 8rpx;
  background: linear-gradient(180deg, #b72e34, #812127);
  color: #fff7eb;
  font-size: 25rpx;
  font-weight: 850;
  line-height: 1;
  padding: 0;
  text-align: center;
  white-space: nowrap;
  box-sizing: border-box;
}

.consult-input button::after {
  border: 0;
}

.consult-input button[disabled] {
  opacity: 0.52;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: calc(128rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(181, 130, 73, 0.36);
  background:
    linear-gradient(180deg, rgba(255, 249, 236, 0.98), rgba(240, 215, 178, 0.98)),
    #f2dcbb;
  box-shadow: 0 -14rpx 34rpx rgba(71, 43, 25, 0.14);
  padding: 10rpx 16rpx calc(12rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.bottom-tab {
  position: relative;
  display: flex;
  flex: 1 1 0;
  width: auto;
  min-width: 0;
  height: 100%;
  align-items: center;
  justify-content: center;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: #173d31;
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 27rpx;
  font-weight: 950;
  line-height: 1;
  padding: 0;
  box-sizing: border-box;
}

.bottom-tab.active {
  color: #aa2b31;
}

.tab-core {
  position: relative;
  width: 190rpx;
  height: 98rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
}

.bottom-tab.active .tab-core {
  background: rgba(255, 250, 241, 0.72);
  box-shadow:
    inset 0 0 0 1rpx rgba(170, 43, 49, 0.13),
    0 5rpx 12rpx rgba(96, 50, 22, 0.08);
}

.tab-icon-wrap {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  width: 52rpx;
  height: 52rpx;
}

.tab-label {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  white-space: nowrap;
  text-align: center;
}

.tab-badge {
  position: absolute;
  top: -2rpx;
  right: -22rpx;
  min-width: 34rpx;
  height: 23rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(170, 43, 49, 0.28);
  border-radius: 6rpx;
  background: rgba(170, 43, 49, 0.08);
  color: #aa2b31;
  font-size: 16rpx;
  font-weight: 900;
}
