page {
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 250, 240, 0.9), transparent 520rpx),
    linear-gradient(180deg, #dcc5ad 0, #efe6d6 720rpx, #f7f0e6 100%);
  color: #2f2017;
  font-family: "Noto Serif SC", "Source Han Serif SC", "Songti SC", "Microsoft YaHei", sans-serif;
}

image {
  display: block;
}

button {
  font: inherit;
}
